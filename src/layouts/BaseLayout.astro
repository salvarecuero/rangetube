---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: object | object[];
}

const {
  title = "RangeTube — Loop a Section of Any YouTube Video Free",
  description = "Pick a start and end time and loop only that part of any YouTube video — endlessly. Free A-B looper for practice. No sign-up.",
  ogImage,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
  </head>
  <body class="flex min-h-screen flex-col bg-bg text-ink">
    <slot />
    <Footer />
  </body>
</html>
